<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="UI Automation Suite" verbose="1" thread-count="1" parallel="none">

    <!-- ============================================================ -->
    <!-- Listener — handles logging and screenshots automatically     -->
    <!-- ============================================================ -->
    <listeners>
        <listener class-name="com.framework.listeners.TestListener"/>
    </listeners>

    <!-- ============================================================ -->
    <!-- Global parameters — override config.properties values       -->
    <!-- Remove these tags to fall back to config.properties defaults -->
    <!-- ============================================================ -->
    <parameter name="browser"  value="chrome"/>
    <parameter name="headless" value="false"/>

    <!-- ============================================================ -->
    <!-- Test groups                                                  -->
    <!-- ============================================================ -->

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.framework.tests.ui"/>
        </packages>
    </test>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.framework.tests.ui"/>
        </packages>
    </test>

</suite>